#!/usr/bin/env bash
set -euo pipefail

# gitolite 会提供 GL_REPO（不一定所有场景都有，但大多数有）
REPO="${GL_REPO:-unknown}"
URL="$(git config --get relay.github.url || true)"
[ -z "$URL" ] && exit 0

# 确保有 github remote
if ! git remote get-url github >/dev/null 2>&1; then
  git remote add github "$URL"
else
  git remote set-url github "$URL"
fi

# 仅同步 heads + tags，避免 mirror/force 带来的意外
# --prune：删除 GitHub 上已不存在的分支/标签（让 GitHub 跟随 VPS）
git push --prune github \
  'refs/heads/*:refs/heads/*' \
  'refs/tags/*:refs/tags/*'
